# --- AI (script generation) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Stock media ---
PEXELS_API_KEY=
PIXABAY_API_KEY=
FREESOUND_API_KEY=
FREESOUND_CLIENT_ID=

# --- YouTube (OAuth refresh token flow) ---
# Obtain CLIENT_ID and CLIENT_SECRET from Google Cloud Console > Credentials > OAuth client (desktop app)
# Obtain REFRESH_TOKEN by running scripts/bootstrap_youtube_token.ts once locally
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
YT_CHANNEL_ID=

# --- Optional overrides ---
# WEEKDAY=0          # 0=Mon ... 6=Sun. Default: today UTC.
# DRY_RUN=1          # 1 = build everything but skip upload
# TARGET_MINUTES=11
