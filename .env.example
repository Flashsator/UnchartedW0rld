# --- AI (script generation) ---
# Script generation runs the headless Claude Code CLI (`claude -p`), authenticated
# by a subscription OAuth token (no API billing). Generate it with `claude setup-token`.
CLAUDE_CODE_OAUTH_TOKEN=

# --- TTS (narration) ---
# Azure Speech, neural voices (same voices as before, now licensed for
# commercial use). Create a Speech resource in the Azure Portal; the free F0
# tier covers ~500k chars/month. REGION is e.g. eastus, westeurope, etc.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- Stock media (b-roll video) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=
# Optional third free stock-video source (coverr.co). Leave blank to disable.
COVERR_API_KEY=
# Optional still-photo fallback (unsplash.com): photos become Ken Burns clips
# only when the video sources can't fill a section. Leave blank to disable.
UNSPLASH_ACCESS_KEY=

# --- YouTube (OAuth refresh token flow) ---
# Obtain CLIENT_ID and CLIENT_SECRET from Google Cloud Console > Credentials > OAuth client (desktop app)
# Obtain REFRESH_TOKEN by running scripts/bootstrap_youtube_token.ts once locally
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
YT_CHANNEL_ID=

# --- Optional overrides ---
# WEEKDAY=0          # 0=Mon ... 6=Sun. Default: today UTC.
# DRY_RUN=1          # 1 = build everything but skip upload
# TARGET_MINUTES=11
#
# BGM/ambient come solely from official YouTube Audio Library tracks committed
# under assets/yt_music/ (the one source YouTube does not Content-ID-claim).
